{
  "name": "ravivarvichar-cms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client,admin -c blue,green,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:admin\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "dev:admin": "npm run dev -w apps/admin",
    "seed": "npm run seed -w apps/server",
    "start:server": "npm start -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
